<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="8dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvItemOrderId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mã đơn: #20260630"
                android:textColor="#222222"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvItemOrderStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="CHỜ XỬ LÝ"
                android:textColor="#FF5722"
                android:textSize="12sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginVertical="8dp"
            android:background="#EFEFEF" />

        <TextView
            android:id="@+id/tvItemOrderDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ngày đặt: 30/06/2026 14:00"
            android:textColor="#666666"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvItemReceiver"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Người nhận: Nguyễn Văn A"
            android:textColor="#666666"
            android:textSize="13sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginVertical="8dp"
            android:background="#EFEFEF" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_centerVertical="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/order_history_total"
                    android:textColor="#212121"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvItemTotalPay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="450.000đ"
                    android:textColor="#FF5722"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnViewOrderDetails"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_alignParentEnd="true"
                android:background="@drawable/filter_button"
                android:backgroundTint="@null"
                android:stateListAnimator="@null"
                android:text="@string/order_history_see_details"
                android:textColor="#007BFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingHorizontal="14dp"
                android:textAllCaps="false"/>
        </RelativeLayout>
        <LinearLayout
            android:id="@+id/llCancelOrderContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:gravity="end"
            android:visibility="gone">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCancelOrder"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:background="@drawable/cancel_order_button"
                android:backgroundTint="@null"
                android:stateListAnimator="@null"
                android:text="Hủy đơn hàng"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingHorizontal="16dp"
                android:textAllCaps="false"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>