<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"

    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F8F8F8">

    <!-- SEARCH BOX -->

    <EditText
        android:id="@+id/edt_search"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:hint="Tìm kiếm sản phẩm..."
        android:inputType="text"

        android:paddingStart="14dp"
        android:paddingEnd="14dp"

        android:textSize="14sp"
        android:drawableStart="@drawable/ic_search"/>


    <!-- HISTORY -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/txt_history_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"

            android:text="Lịch sử tìm kiếm"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#222222"/>

        <TextView
            android:id="@+id/btn_clear_keyword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="Xóa"
            android:textColor="#1976D2"
            android:textStyle="bold"/>
    </LinearLayout>


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_keyword_history"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="8dp"/>


    <!-- RECENT PRODUCT -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/txt_recent_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"

            android:text="Sản phẩm đã xem gần đây"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#222222"/>

        <TextView
            android:id="@+id/btn_clear_recent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="Xóa"
            android:textColor="#1976D2"
            android:textStyle="bold"/>
    </LinearLayout>


    <!-- TĂNG CHIỀU CAO -->

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_recent_product"
        android:layout_width="match_parent"
        android:layout_height="340dp"
        android:layout_marginTop="8dp"/>


    <!-- SEARCH RESULT -->

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_search_result"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"

        android:layout_marginTop="12dp"
        android:visibility="gone"/>

</LinearLayout>