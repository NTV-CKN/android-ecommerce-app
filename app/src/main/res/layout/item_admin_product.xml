<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@color/tech_surface">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_main_image_iap"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:scaleType="centerCrop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.SmallComponent"
            tools:src="@tools:sample/avatars" />

        <TextView
            android:id="@+id/tv_product_name_iap"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/tech_text_main"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/ib_options_iap"
            app:layout_constraintStart_toEndOf="@+id/iv_main_image_iap"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/ib_options_iap"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Options"
            android:src="@drawable/ic_more_horiz_24px"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="SpeakableTextPresentCheck" />

        <TextView
            android:id="@+id/tv_product_code_iap"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/tech_text_muted"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="@+id/tv_product_name_iap"
            app:layout_constraintTop_toBottomOf="@+id/tv_product_name_iap"
            tools:text="Mã: SP-SONY-XM4" />

        <TextView
            android:id="@+id/tv_product_price_range_iap"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/tech_cta_action"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/tv_product_name_iap"
            app:layout_constraintTop_toBottomOf="@+id/tv_product_code_iap"
            tools:text="4.200.000đ - 5.500.000đ" />

        <TextView
            android:id="@+id/tv_variant_count_iap"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@color/tech_background"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:textColor="@color/tech_primary"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@+id/tv_product_name_iap"
            app:layout_constraintTop_toBottomOf="@+id/tv_product_price_range_iap"
            tools:text="3 biến thể" />

        <TextView
            android:id="@+id/tv_total_stock_iap"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@color/tech_background"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:textColor="@color/tech_accent"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@+id/tv_variant_count_iap"
            app:layout_constraintTop_toTopOf="@+id/tv_variant_count_iap"
            tools:text="Kho: 142" />

        <TextView
            android:id="@+id/tv_warranty_months_iap"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@color/tech_background"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:textColor="@color/tech_success"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@+id/tv_total_stock_iap"
            app:layout_constraintTop_toTopOf="@+id/tv_total_stock_iap"
            tools:text="Bảo hành: 12 tháng" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>