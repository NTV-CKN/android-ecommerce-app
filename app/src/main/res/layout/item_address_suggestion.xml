<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true"
    android:paddingHorizontal="20dp"
    android:paddingVertical="16dp">

    <ImageView
        android:id="@+id/iv_icon_address_suggestion"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/ic_location_chip_24px"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#666666" />

    <TextView
        android:id="@+id/tv_title_address_suggestion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#212121"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/iv_icon_address_suggestion"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Hà Nội Tower" />

    <TextView
        android:id="@+id/tv_subtitle_address_suggestion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="#757575"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/tv_title_address_suggestion"
        app:layout_constraintTop_toBottomOf="@id/tv_title_address_suggestion"
        tools:text="49 Hai Bà Trưng, Trần Hưng Đạo, Hoàn Kiếm, Hà Nội" />

    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:background="#E0E0E0"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/tv_title_address_suggestion"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle_address_suggestion" />

</androidx.constraintlayout.widget.ConstraintLayout>