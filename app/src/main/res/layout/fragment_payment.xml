<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@android:color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tv_title_payment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_payment"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/card_address"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card_rounded"
            android:padding="12dp"
            app:layout_constraintTop_toBottomOf="@id/tv_title_payment"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tv_label_address"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/payment_user_address"
                android:textStyle="bold"
                android:textSize="13sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/payment_tv_change_address" />

            <TextView
                android:id="@+id/payment_tv_change_address"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/payment_change_address"
                android:textColor="@color/tech_primary"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/payment_tv_receiver_name_phone"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textStyle="bold"
                android:textSize="13sp"
                android:text="Nguyễn Văn A · 0901 234 567"
                app:layout_constraintTop_toBottomOf="@id/tv_label_address"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/payment_tv_address_detail"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="12sp"
                android:textColor="@android:color/darker_gray"
                android:text="123 Lê Văn Việt, P. Tăng Nhơn Phú A, TP. Thủ Đức"
                app:layout_constraintTop_toBottomOf="@id/payment_tv_receiver_name_phone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/tv_label_products"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/payment_title_product"
            android:textStyle="bold"
            android:textSize="13sp"
            app:layout_constraintTop_toBottomOf="@id/card_address"
            app:layout_constraintStart_toStartOf="parent" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_payment_items"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:nestedScrollingEnabled="false"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="1.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_label_products"
            tools:listitem="@layout/item_payment_product" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/payment_card_voucher"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card_rounded"
            android:padding="12dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/rv_payment_items"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/payment_img_voucher_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_voucher"
                android:contentDescription="Voucher"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/payment_tv_voucher_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/payment_tv_choice_voucher"
                android:textSize="13sp"
                android:textColor="@android:color/black"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/payment_img_voucher_icon"
                app:layout_constraintEnd_toStartOf="@id/img_voucher_arrow" />

            <ImageView
                android:id="@+id/img_voucher_arrow"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/arrow_down_float"
                android:rotation="270"
                android:contentDescription="Mở chọn voucher"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/payment_tv_label_payment_method"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/payment_method"
            android:textStyle="bold"
            android:textSize="13sp"
            app:layout_constraintTop_toBottomOf="@id/payment_card_voucher"
            app:layout_constraintStart_toStartOf="parent" />

        <RadioGroup
            android:id="@+id/rg_payment_method"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/payment_tv_label_payment_method"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <RadioButton
                android:id="@+id/rb_cod"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:text="@string/payment_cod"
                android:textSize="13sp"
                android:checked="true" />

            <RadioButton
                android:id="@+id/rb_bank_transfer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:text="@string/payment_online"
                android:textSize="13sp" />

        </RadioGroup>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/payment_card_total"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card_rounded"
            android:padding="14dp"
            app:layout_constraintTop_toBottomOf="@id/rg_payment_method"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/payment_tv_label_subtotal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/payment_tam_early_price"
                android:textSize="13sp"
                android:textColor="@android:color/darker_gray"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/payment_tv_subtotal_value" />

            <TextView
                android:id="@+id/payment_tv_subtotal_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="740.000đ"
                android:textSize="13sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/payment_tv_label_shipping_fee"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/payment_shipfee"
                android:textSize="13sp"
                android:textColor="@android:color/darker_gray"
                app:layout_constraintTop_toBottomOf="@id/payment_tv_label_subtotal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/tv_shipping_fee_value" />

            <TextView
                android:id="@+id/tv_shipping_fee_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Miễn phí"
                android:textSize="13sp"
                android:textColor="#2E7D32"
                app:layout_constraintTop_toBottomOf="@id/payment_tv_subtotal_value"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tv_label_discount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/payment_discount"
                android:textSize="13sp"
                android:textColor="@android:color/darker_gray"
                app:layout_constraintTop_toBottomOf="@id/payment_tv_label_shipping_fee"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/tv_discount_value" />

            <TextView
                android:id="@+id/tv_discount_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="-0đ"
                android:textSize="13sp"
                android:textColor="#D32F2F"
                app:layout_constraintTop_toBottomOf="@id/tv_shipping_fee_value"
                app:layout_constraintEnd_toEndOf="parent" />

            <View
                android:id="@+id/divider_total"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginTop="10dp"
                android:background="#E0E0E0"
                app:layout_constraintTop_toBottomOf="@id/tv_label_discount"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/payment_tv_label_total"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/payment_total_price_value"
                android:textStyle="bold"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@id/divider_total"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/payment_tv_total_value" />

            <TextView
                android:id="@+id/payment_tv_total_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="740.000đ"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#D32F2F"
                app:layout_constraintTop_toBottomOf="@id/divider_total"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <Button
            android:id="@+id/btn_place_order"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="20dp"
            android:text="@string/payment"
            android:textStyle="bold"
            style="@style/ButtonPositive"
            app:layout_constraintTop_toBottomOf="@id/payment_card_total"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>